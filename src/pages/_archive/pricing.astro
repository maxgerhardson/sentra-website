---
import Base from '../layouts/Base.astro';
---

<Base title="Pricing" description="sentrik pricing — free tier available, enterprise tiers for advanced needs.">

<section class="pricing-hero">
  <div class="container">
    <h1>Simple, transparent pricing</h1>
    <p class="pricing-sub">Free tier available. Enterprise tiers for teams that need advanced governance.</p>
  </div>
</section>

<section class="tiers">
  <div class="container">
    <div class="tier-grid">

      <div class="tier-card">
        <div class="tier-header">
          <h3>Free</h3>
          <div class="tier-price"><span class="price-amount">$0</span><span class="price-period">/mo</span><span class="price-seat">per seat</span></div>
        </div>
        <p class="tier-desc">Everything you need to start governing AI-generated code.</p>
        <ul class="tier-features">
          <li>Unlimited scans and gates</li>
          <li>9 free standards packs (IEC 62304, OWASP, SOC2, HIPAA, PCI DSS, ISO 27001, PHP Security, Kotlin Security, Supply Chain Security)</li>
          <li>Management dashboard</li>
          <li>MCP server for AI coding tools</li>
          <li>REST API (75+ endpoints)</li>
          <li>HTML, JUnit, SARIF, CSV reports</li>
          <li>Pre-commit hooks</li>
          <li>SBOM generation &amp; license scanning</li>
          <li>Heuristic confidence scoring</li>
          <li>Vulnerability scanning (OSV.dev)</li>
          <li>Community support (GitHub Discussions)</li>
        </ul>
        <a href="/blog/getting-started-in-5-minutes" class="btn btn-outline tier-cta">Install Free</a>
      </div>

      <div class="tier-card">
        <div class="tier-header">
          <h3>Team</h3>
          <div class="tier-price"><span class="price-amount">$29</span><span class="price-period">/mo</span><span class="price-seat">per seat</span></div>
        </div>
        <p class="tier-desc">Performance and intelligence for growing teams.</p>
        <ul class="tier-features">
          <li>Everything in Free, plus:</li>
          <li>Dashboard AI Chat (Fix with AI)</li>
          <li>PR decoration</li>
          <li>Work item traceability</li>
          <li>Auto-remediation (--fix + auto-PR generation)</li>
          <li>Parallel scanning (multi-threaded)</li>
          <li>Change impact analysis</li>
          <li>Architecture rules enforcement</li>
          <li>Email support</li>
        </ul>
        <a href="#" class="btn btn-primary tier-cta" data-tier="team" onclick="startCheckout('team')">Get Started</a>
      </div>

      <div class="tier-card featured">
        <div class="tier-badge">Most Popular</div>
        <div class="tier-header">
          <h3>Organization</h3>
          <div class="tier-price"><span class="price-amount">$99</span><span class="price-period">/mo</span><span class="price-seat">per seat</span></div>
        </div>
        <p class="tier-desc">Advanced governance for compliance-driven organizations.</p>
        <ul class="tier-features">
          <li>Everything in Team, plus:</li>
          <li>6 industry packs (IEC 81001, 21 CFR Part 11, ISO 14971, MISRA C/C++, DO-178C, ISO 26262)</li>
          <li>Pack overrides (tune rules per-project)</li>
          <li>Severity rescoring (heuristic)</li>
          <li>Governance profiles</li>
          <li>Multi-repo organization dashboard</li>
          <li>Long-term metrics database &amp; trends</li>
          <li>LLM-powered confidence scoring</li>
          <li>Policy-as-Code engine</li>
          <li>Priority email support</li>
        </ul>
        <a href="#" class="btn btn-primary tier-cta" data-tier="org" onclick="startCheckout('org')">Get Started</a>
      </div>

      <div class="tier-card">
        <div class="tier-header">
          <h3>Enterprise</h3>
          <div class="tier-price"><span class="price-amount">Custom</span></div>
        </div>
        <p class="tier-desc">Full platform for regulated industries and large teams.</p>
        <ul class="tier-features">
          <li>Everything in Organization, plus:</li>
          <li>Custom pack authoring &amp; import</li>
          <li>Audit logging</li>
          <li>Async approval gates</li>
          <li>RBAC (5 roles, 10+ permissions)</li>
          <li>Auditor portal with time-boxed access</li>
          <li>Evidence export for compliance audits</li>
          <li>GRC platform integration (Drata, Vanta, Secureframe)</li>
          <li>C/C++ semantic analysis (clang-tidy/cppcheck)</li>
          <li>AI agent compliance SDK</li>
          <li>Dedicated support + implementation assistance</li>
        </ul>
        <!-- TODO: Add screenshot of org dashboard -->
        <!-- TODO: Add screenshot of auditor portal -->
        <a href="mailto:sales@sentrik.dev?subject=Enterprise%20Inquiry" class="btn btn-primary tier-cta">Contact Sales</a>
        <!-- Enterprise stays as mailto — custom pricing requires sales conversation -->
      </div>

    </div>
  </div>
</section>

<section class="trial-banner">
  <div class="container trial-inner">
    <h2>Try Enterprise free for 30 days</h2>
    <p>No credit card required. All enterprise features unlocked.</p>
    <pre><code>npm install -g sentrik && sentrik dashboard</code></pre>
  </div>
</section>

<section class="faq-link">
  <div class="container faq-link-inner">
    <h2>Have questions?</h2>
    <p>Check our FAQ for answers about setup, licensing, CI/CD, and more.</p>
    <div class="faq-link-actions">
      <a href="/faq" class="btn btn-outline">View FAQ</a>
      <a href="/support" class="btn btn-outline">Contact Support</a>
    </div>
  </div>
</section>

</Base>

<style>
  .pricing-hero { padding: 6rem 0 3rem; text-align: center; }
  .pricing-sub { color: var(--color-text-muted); font-size: 1.2rem; margin-top: 1rem; }

  .tier-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }

  .tier-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .tier-card.featured { border-color: var(--color-primary); box-shadow: 0 0 30px rgba(124, 58, 237, 0.2); }
  .tier-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: #fff;
    padding: 0.25rem 1rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .tier-header { margin-bottom: 1rem; }
  .tier-header h3 { font-size: 1.3rem; margin-bottom: 0.5rem; }
  .price-amount { font-size: 2.5rem; font-weight: 800; }
  .price-period { color: var(--color-text-muted); font-size: 1rem; margin-left: 0.25rem; }
  .price-seat { display: block; color: var(--color-text-muted); font-size: 0.8rem; margin-top: 0.15rem; }

  .tier-desc { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: 1.5rem; }

  .tier-features { list-style: none; margin-bottom: 2rem; flex: 1; }
  .tier-features li {
    padding: 0.4rem 0;
    padding-left: 1.5rem;
    position: relative;
    font-size: 0.95rem;
    color: var(--color-text);
  }
  .tier-features li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: var(--color-success);
    font-weight: 700;
  }
  .tier-features li:first-child { font-weight: 600; color: var(--color-primary-light); }
  .tier-features li:first-child::before { content: ""; }

  .tier-cta { text-align: center; width: 100%; }

  .trial-banner { background: var(--color-bg-alt); text-align: center; }
  .trial-banner h2 { margin-bottom: 0.75rem; }
  .trial-banner p { color: var(--color-text-muted); margin-bottom: 1.5rem; }
  .trial-banner pre { display: inline-block; padding: 0.75rem 2rem; }

  .faq-link { background: var(--color-bg-alt); text-align: center; }
  .faq-link-inner p { color: var(--color-text-muted); margin: 0.75rem 0 1.5rem; }
  .faq-link-actions { display: flex; gap: 1rem; justify-content: center; }

  @media (max-width: 1024px) { .tier-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) {
    .tier-grid { grid-template-columns: 1fr; }
    .faq-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  const CHECKOUT_URLS = {
    team: 'https://buy.stripe.com/test_9B600i0Uxemv2m13Fe7bW01',
    org: 'https://buy.stripe.com/test_3cIeVc8mZbaj3q58Zy7bW00',
  };

  function startCheckout(tier) {
    const url = CHECKOUT_URLS[tier];
    if (url) {
      window.location.href = url;
    } else {
      window.location.href = 'mailto:sales@sentrik.dev?subject=' + encodeURIComponent(tier.charAt(0).toUpperCase() + tier.slice(1)) + '%20License';
    }
  }
</script>
