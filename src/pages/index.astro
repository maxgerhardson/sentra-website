---
import ComingSoon from '../layouts/ComingSoon.astro';
---

<ComingSoon title="The Compliance Layer for AI-Generated Code">

<!-- Hero -->
<section class="hero">
  <div class="container hero-inner">
    <div class="hero-badge">Early Access</div>
    <h1>Stop auditing AI code<br /><span class="gradient-text">by hand</span></h1>
    <p class="hero-sub">
      Sentrik scans every commit against 20 regulatory frameworks, blocks non-compliant code in CI, and generates audit evidence automatically. One CLI. Zero config.
    </p>
    <div class="hero-actions">
      <a href="#early-access" class="btn btn-primary btn-lg">Get Early Access</a>
    </div>
  </div>
</section>

<!-- The Problem -->
<section class="problem">
  <div class="container">
    <h2 class="section-title">The Problem</h2>
    <p class="section-sub">AI writes code faster than humans can review it. Compliance can't keep up.</p>
    <div class="problem-grid">
      <div class="problem-card">
        <div class="problem-stat">6 weeks</div>
        <p>average time to prepare compliance evidence for a single audit</p>
      </div>
      <div class="problem-card">
        <div class="problem-stat">4&ndash;5 tools</div>
        <p>required today to cover security, compliance, and audit evidence</p>
      </div>
      <div class="problem-card">
        <div class="problem-stat">36%</div>
        <p>of AI-generated code contains security vulnerabilities <a href="https://www.theregister.com/2025/01/24/ai_code_security/" target="_blank" rel="noopener" class="stat-cite">[Stanford]</a></p>
      </div>
      <div class="problem-card">
        <div class="problem-stat">434</div>
        <p>rules across 20 regulatory frameworks, ready out of the box</p>
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section class="how-it-works">
  <div class="container">
    <h2 class="section-title">Three Commands. Full Compliance.</h2>
    <div class="steps-grid">
      <div class="step-card">
        <div class="step-num">1</div>
        <h3>Scan</h3>
        <code class="step-cmd">sentrik scan</code>
        <p>476 rules check your code against IEC 62304, HIPAA, SOC2, OWASP, GDPR, EU AI Act, and 14 more frameworks. Findings map to specific regulatory clauses.</p>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <h3>Gate</h3>
        <code class="step-cmd">sentrik gate</code>
        <p>Block non-compliant code in CI. PR comments show exactly which regulation you're violating.</p>
        <pre class="step-yaml"><code>- name: Compliance Gate
  run: sentrik gate
    --git-range origin/main...HEAD
    --decorate-pr</code></pre>
      </div>
      <div class="step-card">
        <div class="step-num">3</div>
        <h3>Ship</h3>
        <code class="step-cmd">sentrik attest</code>
        <p>Generate cryptographically signed attestations, per-framework compliance reports, and audit-ready evidence bundles. No more 6-week evidence sprints.</p>
      </div>
    </div>
  </div>
</section>

<!-- Terminal Demo -->
<section class="demo">
  <div class="container">
    <h2 class="section-title">See It In Action</h2>
    <div class="terminal">
      <div class="terminal-header">
        <span class="terminal-dot red"></span>
        <span class="terminal-dot yellow"></span>
        <span class="terminal-dot green"></span>
        <span class="terminal-title">sentrik</span>
      </div>
      <div class="terminal-body">
        <div id="main-player"></div>
      </div>
    </div>

    <div class="demo-tabs">
      <button class="demo-tab active" data-cast="/recordings/05-full-lifecycle.cast">Full Lifecycle</button>
      <button class="demo-tab" data-cast="/recordings/01-init-and-scan.cast">Scan &amp; Findings</button>
      <button class="demo-tab" data-cast="/recordings/02-fix-and-gate.cast">Fix &amp; Gate</button>
      <button class="demo-tab" data-cast="/recordings/03-supply-chain.cast">Supply Chain</button>
      <button class="demo-tab" data-cast="/recordings/04-compliance.cast">Reports</button>
      <span class="demo-tab-divider"></span>
      <button class="demo-tab" data-cast="/recordings/quality-score.cast">Quality Score</button>
      <button class="demo-tab" data-cast="/recordings/project-profile.cast">Project Profile</button>
      <button class="demo-tab" data-cast="/recordings/design-review.cast">Design Review</button>
      <button class="demo-tab" data-cast="/recordings/expertise.cast">Expertise Check</button>
    </div>
  </div>
</section>

<!-- Mid-page CTA -->
<section class="mid-cta">
  <div class="container" style="text-align:center">
    <a href="#early-access" class="btn btn-primary btn-lg">Get Early Access</a>
  </div>
</section>

<!-- Dashboard & AI -->
<section class="dashboard-section">
  <div class="container">
    <h2 class="section-title">A Compliance Dashboard That Actually Helps</h2>
    <p class="section-sub">Real-time compliance scores, findings browser, AI-powered fixes, and one-click audit evidence &mdash; all in the browser.</p>

    <div class="showcase-block">
      <div class="showcase-text">
        <h3>Compliance Overview</h3>
        <p>See your compliance score, finding counts by severity, gate status, and scan duration at a glance. Governance banners flag when human review is required before merge.</p>
      </div>
      <div class="showcase-img">
        <img src="/images/dashboard-overview.png" alt="Sentrik dashboard showing compliance score, findings summary, and gate status" class="screenshot expandable" loading="lazy" />
      </div>
    </div>

    <div class="showcase-block reverse">
      <div class="showcase-text">
        <h3>Findings with Code Context</h3>
        <p>Every finding shows the exact file, line number, regulatory clause, and code snippet. Filter by severity, rule, or framework. Export to CSV for auditors.</p>
      </div>
      <div class="showcase-img">
        <img src="/images/finding-detail.png" alt="Finding detail view showing code snippet with compliance violation highlighted" class="screenshot expandable" loading="lazy" />
      </div>
    </div>

    <div class="showcase-block">
      <div class="showcase-text">
        <h3>Requirement Drift Detection</h3>
        <p>Sentrik compares your code against documented requirements and flags when they diverge. When drift is detected, work items are automatically created in GitHub Issues, Azure DevOps, or Jira &mdash; assigned, labeled, and linked to the finding. No manual triage.</p>
      </div>
      <div class="showcase-img">
        <img src="/images/dash-work-items.png" alt="Work items automatically created from requirement drift findings" class="screenshot expandable" loading="lazy" />
      </div>
    </div>

    <div class="showcase-block reverse">
      <div class="showcase-text">
        <h3>Fix with AI</h3>
        <p>Click any finding, chat with an LLM, and apply the fix &mdash; all from the browser. Compliance officers triage findings without touching an IDE.</p>
      </div>
      <div class="showcase-img">
        <img src="/images/ai-chat-panel.png" alt="AI chat panel explaining how to fix a compliance finding" class="screenshot expandable" loading="lazy" />
      </div>
    </div>

    <div class="showcase-block">
      <div class="showcase-text">
        <h3>AI-Assisted Code Generation</h3>
        <p>Claude Code, Cursor, and VS Code call Sentrik via MCP. The AI checks compliance rules <em>before</em> writing code &mdash; so generated code passes the gate on the first try. The VS Code extension scans on every save with inline diagnostics.</p>
      </div>
      <div class="showcase-img">
        <img src="/images/mcp-in-action.png" alt="AI agent checking compliance rules during code generation" class="screenshot expandable" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- Code Intelligence -->
<section class="intelligence-section">
  <div class="container">
    <h2 class="section-title">Code Intelligence</h2>
    <p class="section-sub">Sentrik understands your codebase &mdash; it scores quality, profiles your stack, and knows who should review what.</p>

    <div class="showcase-block">
      <div class="showcase-text">
        <h3>Quality Gradient Scoring</h3>
        <p>A 0&ndash;100 quality score across six dimensions: compliance, complexity, test coverage, documentation, consistency, and dependency health. Track trends over time and set minimum thresholds in your gate.</p>
      </div>
      <div class="showcase-img">
        <img src="/images/quality-score-dashboard.png" alt="Quality score dashboard showing 6 dimensions with trend chart" class="screenshot expandable" loading="lazy" />
      </div>
    </div>

    <div class="showcase-block reverse">
      <div class="showcase-text">
        <h3>Project Profile &amp; Expertise Tracking</h3>
        <p>Auto-detects languages, frameworks, architecture patterns, and conventions. Builds developer expertise profiles from git history. When a PR touches code outside someone's expertise, it flags it for senior review.</p>
      </div>
      <div class="showcase-img">
        <img src="/images/project-profile-dashboard.png" alt="Project profile showing detected languages, frameworks, and module map" class="screenshot expandable" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- Key Features -->
<section class="value-props">
  <div class="container">
    <h2 class="section-title">One Tool. Full Compliance Lifecycle.</h2>
    <div class="props-grid">
      <div class="prop-card">
        <div class="prop-icon">&#x26A1;</div>
        <h3>Scan in Seconds</h3>
        <p>476 rules across 20 frameworks. SQL injection, hardcoded secrets, AI model security, supply chain risks &mdash; mapped to specific regulatory clauses.</p>
      </div>
      <div class="prop-card">
        <div class="prop-icon">&#x26D4;</div>
        <h3>Gate Every PR</h3>
        <p>Block non-compliant code in CI/CD. GitHub Actions, Azure Pipelines, GitLab CI. PR comments show exactly which rule was violated.</p>
      </div>
      <div class="prop-card">
        <div class="prop-icon">&#x1F4CB;</div>
        <h3>Audit Evidence</h3>
        <p>Per-framework compliance reports, trust center pages, signed attestations, and audit-ready ZIP bundles. Generated in seconds.</p>
      </div>
      <div class="prop-card">
        <div class="prop-icon">&#x1F4E6;</div>
        <h3>Supply Chain Security</h3>
        <p>SBOM generation, CVE scanning against OSV.dev, license compliance, and secrets detection. Auto-fix vulnerable deps and create PRs.</p>
      </div>
      <div class="prop-card">
        <div class="prop-icon">&#x1F9E0;</div>
        <h3>Code Intelligence</h3>
        <p>Quality scoring, project profiling, expertise-gap detection, and design decision auditing with AI-powered review.</p>
      </div>
      <div class="prop-card">
        <div class="prop-icon">&#x1F517;</div>
        <h3>Full Traceability</h3>
        <p>Requirements &rarr; code &rarr; tests &rarr; work items &rarr; audit evidence. Detect requirement drift automatically and create work items in GitHub, Azure DevOps, or Jira.</p>
      </div>
    </div>
  </div>
</section>

<!-- Integrations -->
<section class="integrations">
  <div class="container">
    <h2 class="section-title">Works With Your Stack</h2>
    <div class="integrations-grid">
      <div class="integration-group">
        <div class="integration-label">CI/CD</div>
        <div class="integration-items">
          <span class="integration-item">GitHub Actions</span>
          <span class="integration-item">Azure Pipelines</span>
          <span class="integration-item">GitLab CI</span>
        </div>
      </div>
      <div class="integration-group">
        <div class="integration-label">Work Items</div>
        <div class="integration-items">
          <span class="integration-item">GitHub Issues</span>
          <span class="integration-item">Azure DevOps</span>
          <span class="integration-item">Jira</span>
        </div>
      </div>
      <div class="integration-group">
        <div class="integration-label">AI Agents</div>
        <div class="integration-items">
          <span class="integration-item">Claude Code</span>
          <span class="integration-item">Cursor</span>
          <span class="integration-item">Copilot</span>
        </div>
      </div>
      <div class="integration-group">
        <div class="integration-label">Editors</div>
        <div class="integration-items">
          <span class="integration-item">VS Code</span>
          <span class="integration-item">JetBrains</span>
          <span class="integration-item">Any LSP</span>
        </div>
      </div>
      <div class="integration-group">
        <div class="integration-label">GRC</div>
        <div class="integration-items">
          <span class="integration-item">Drata</span>
          <span class="integration-item">Vanta</span>
          <span class="integration-item">Secureframe</span>
        </div>
      </div>
      <div class="integration-group">
        <div class="integration-label">Output</div>
        <div class="integration-items">
          <span class="integration-item">SARIF</span>
          <span class="integration-item">JUnit XML</span>
          <span class="integration-item">CycloneDX</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Built for Regulated Industries -->
<section class="regulated">
  <div class="container">
    <h2 class="section-title">Built for Regulated Industries</h2>
    <p class="section-sub">From medical devices to aviation software &mdash; Sentrik is designed for teams where compliance isn't optional.</p>
    <div class="regulated-grid">
      <div class="regulated-card">
        <div class="regulated-icon">&#x1F512;</div>
        <h3>Air-Gapped Ready</h3>
        <p>Offline license validation via HMAC. No phone-home, no cloud dependency. Works in classified and air-gapped environments.</p>
      </div>
      <div class="regulated-card">
        <div class="regulated-icon">&#x1F9D1;&#x200D;&#x2696;&#xFE0F;</div>
        <h3>Auditor Portal</h3>
        <p>Dedicated read-only portal for compliance auditors. Generate access tokens, share evidence bundles, and export audit-ready ZIPs.</p>
      </div>
      <div class="regulated-card">
        <div class="regulated-icon">&#x1F6E1;</div>
        <h3>Governance Profiles</h3>
        <p>Three profiles &mdash; strict, standard, permissive &mdash; control human review gates, auto-patching, and gate thresholds per software safety class.</p>
      </div>
      <div class="regulated-card">
        <div class="regulated-icon">&#x270D;</div>
        <h3>Signed Attestations</h3>
        <p>Cryptographic HMAC-SHA256 signatures on every compliance attestation. Tamper-evident audit trails with per-entry integrity verification.</p>
      </div>
    </div>
  </div>
</section>

<!-- Standards -->
<section class="standards">
  <div class="container">
    <h2 class="section-title">20 Regulatory Frameworks. Built In.</h2>
    <p class="section-sub">Medical devices, fintech, healthcare, automotive, aviation, embedded systems.</p>
    <div class="standards-grid">
      <div class="standard-card"><h3>IEC 62304</h3><p>Medical device software</p></div>
      <div class="standard-card"><h3>OWASP Top 10</h3><p>Web application security</p></div>
      <div class="standard-card"><h3>SOC2</h3><p>Trust services criteria</p></div>
      <div class="standard-card"><h3>HIPAA</h3><p>Healthcare data protection</p></div>
      <div class="standard-card"><h3>PCI DSS</h3><p>Payment card security</p></div>
      <div class="standard-card"><h3>ISO 27001</h3><p>Information security</p></div>
      <div class="standard-card"><h3>EU AI Act</h3><p>AI system governance</p></div>
      <div class="standard-card"><h3>GDPR</h3><p>Data protection &amp; privacy</p></div>
      <div class="standard-card"><h3>DO-178C</h3><p>Aviation software</p></div>
      <div class="standard-card"><h3>ISO 26262</h3><p>Automotive safety</p></div>
    </div>
    <p class="standards-also">Plus MISRA C/C++, ISO 14971, IEC 81001-5-1, 21 CFR Part 11, NIST AI RMF, and language-specific packs for Python, Go, PHP, and Kotlin</p>
  </div>
</section>

<!-- Early Access CTA -->
<section class="cta" id="early-access">
  <div class="container cta-inner">
    <h2>Get Early Access</h2>
    <p class="cta-sub">We're onboarding design partners in medical devices, fintech, and SaaS. Spots are limited.</p>
    <form name="early-access" method="POST" data-netlify="true" class="cta-form" netlify-honeypot="bot-field">
      <input type="hidden" name="form-name" value="early-access" />
      <p class="hidden" style="display:none"><input name="bot-field" /></p>
      <div class="form-row">
        <input type="email" name="email" placeholder="you@company.com" required class="form-input" />
        <button type="submit" class="btn btn-primary">Request Access</button>
      </div>
      <div class="form-row-extra">
        <input type="text" name="company" placeholder="Company (optional)" class="form-input form-input-sm" />
        <input type="text" name="frameworks" placeholder="Frameworks you need (optional)" class="form-input form-input-sm" />
      </div>
    </form>
  </div>
</section>

<!-- Screenshot Lightbox -->
<div id="lightbox" class="lightbox" onclick="closeLightbox()">
  <img id="lightbox-img" src="" alt="" />
</div>

</ComingSoon>

<style>
  /* Hero */
  .hero { padding: 10rem 0 5rem; text-align: center; }
  .hero-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    border-radius: 20px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .hero h1 { margin-bottom: 1.5rem; font-size: 3.2rem; line-height: 1.15; }
  .gradient-text {
    background: linear-gradient(135deg, var(--color-primary-light), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 640px;
    margin: 0 auto 2.5rem;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn-lg { padding: 0.9rem 2.5rem; font-size: 1.1rem; }

  /* Problem */
  .problem { padding: 5rem 0; background: var(--color-bg-alt); }
  .problem-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  .problem-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 2rem; text-align: center; }
  .problem-stat { font-size: 2.5rem; font-weight: 800; color: var(--color-accent); margin-bottom: 0.5rem; }
  .problem-card p { color: var(--color-text-muted); font-size: 0.95rem; line-height: 1.5; }
  .stat-cite { font-size: 0.75rem; color: var(--color-primary-light); }

  /* How It Works */
  .how-it-works { padding: 5rem 0; }
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
  .step-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }
  .step-num {
    width: 40px; height: 40px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 800; font-size: 1.1rem;
    margin: 0 auto 1rem;
  }
  .step-card h3 { margin-bottom: 0.75rem; }
  .step-cmd {
    display: inline-block;
    padding: 0.3rem 0.7rem;
    background: rgba(6, 182, 212, 0.1);
    border: 1px solid rgba(6, 182, 212, 0.2);
    color: var(--color-accent);
    border-radius: 6px;
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }
  .step-card p { color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; }

  /* Shared */
  .section-title { text-align: center; font-size: 2rem; margin-bottom: 0.75rem; }
  .section-sub { text-align: center; color: var(--color-text-muted); font-size: 1.1rem; margin-bottom: 3rem; max-width: 600px; margin-left: auto; margin-right: auto; }
  .screenshot { width: 100%; border-radius: 12px; box-shadow: 0 8px 30px rgba(0,0,0,0.2); border: 1px solid var(--color-border); }
  .screenshot.expandable { cursor: pointer; transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .screenshot.expandable:hover { transform: scale(1.02); box-shadow: 0 12px 40px rgba(0,0,0,0.3); }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.85);
    z-index: 10000;
    cursor: pointer;
    justify-content: center;
    align-items: center;
    padding: 2rem;
  }
  .lightbox.open { display: flex; }
  .lightbox img {
    max-width: 95vw;
    max-height: 92vh;
    border-radius: 12px;
    box-shadow: 0 20px 80px rgba(0, 0, 0, 0.5);
  }

  /* Terminal Demo */
  .demo { padding: 3rem 0 4rem; background: var(--color-bg-alt); }
  .video-wrapper { max-width: 960px; margin: 0 auto; border-radius: 12px; overflow: hidden; border: 1px solid var(--color-border); box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4); }
  .demo-video { width: 100%; display: block; }
  .terminal { max-width: 900px; margin: 0 auto; border-radius: 12px; overflow: hidden; border: 1px solid var(--color-border); box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4); }
  .terminal-header { background: #2d2640; padding: 0.75rem 1rem; display: flex; align-items: center; gap: 0.5rem; }
  .terminal-dot { width: 12px; height: 12px; border-radius: 50%; }
  .terminal-dot.red { background: #ff5f57; }
  .terminal-dot.yellow { background: #ffbd2e; }
  .terminal-dot.green { background: #28c840; }
  .terminal-title { margin-left: 0.5rem; color: var(--color-text-muted); font-size: 0.85rem; }
  .terminal-body { background: #1a1428; padding: 0; overflow: hidden; }
  .demo-tabs { display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.25rem; flex-wrap: wrap; }
  .demo-tab { padding: 0.5rem 1rem; font-size: 0.85rem; font-family: var(--font-sans); font-weight: 500; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-surface); color: var(--color-text-muted); cursor: pointer; transition: all 0.2s ease; }
  .demo-tab:hover { border-color: var(--color-primary); color: var(--color-text); }
  .demo-tab.active { border-color: var(--color-primary); background: var(--color-primary); color: #fff; }
  .demo-tab-divider { width: 1px; background: var(--color-border); margin: 0 0.25rem; align-self: stretch; }
  #main-player { min-height: 300px; }
  :global(.ap-wrapper) { border-radius: 0 !important; }

  /* Mid-page CTA */
  .mid-cta { padding: 3rem 0; }

  /* Dashboard Section */
  .dashboard-section { padding: 5rem 0; background: var(--color-bg-alt); }
  .showcase-block { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; margin-bottom: 4rem; max-width: 1000px; margin-left: auto; margin-right: auto; }
  .showcase-block:last-child { margin-bottom: 0; }
  .showcase-block.reverse { direction: rtl; }
  .showcase-block.reverse > * { direction: ltr; }
  .showcase-text h3 { font-size: 1.4rem; margin-bottom: 0.75rem; }
  .showcase-text p { color: var(--color-text-muted); line-height: 1.7; }

  /* Code Intelligence */
  .intelligence-section { padding: 5rem 0; }

  /* Value Props */
  .value-props { padding: 5rem 0; background: var(--color-bg-alt); }
  .props-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .prop-card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.75rem; transition: border-color 0.2s; }
  .prop-card:hover { border-color: var(--color-primary); }
  .prop-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
  .prop-card h3 { margin-bottom: 0.5rem; }
  .prop-card p { color: var(--color-text-muted); font-size: 0.9rem; line-height: 1.6; }

  /* CI YAML snippet */
  .step-yaml {
